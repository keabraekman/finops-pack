# AWS Savings Review web app settings
FINOPS_WEB_BASE_URL=http://localhost:8000
FINOPS_WEB_DATA_DIR=web_data
FINOPS_WEB_DB_PATH=web_data/leadgen.sqlite3
FINOPS_WEB_DEFAULT_REGIONS=us-east-1,us-west-2,us-west-1
FINOPS_WEB_SESSION_NAME=finops-pack-web
FINOPS_WEB_COLLECT_CE_RESOURCE_DAILY=true
FINOPS_WEB_RATE_LIMIT_SAFE_MODE=true

# Replace with the trusted AWS account ID used in the trust policy instructions.
FINOPS_WEB_TRUSTED_AWS_ACCOUNT_ID=111122223333

# Replace with your booking link.
FINOPS_WEB_REPORT_CTA_LABEL=Book an implementation review
FINOPS_WEB_REPORT_CTA_URL=https://calendly.com/replace-me/aws-savings-review

# Optional SMTP settings for lead confirmations and internal notifications.
FINOPS_WEB_FROM_EMAIL=reports@example.com
FINOPS_WEB_NOTIFY_EMAIL=ops@example.com
FINOPS_WEB_SMTP_HOST=smtp.example.com
FINOPS_WEB_SMTP_PORT=587
FINOPS_WEB_SMTP_USERNAME=smtp-user
FINOPS_WEB_SMTP_PASSWORD=smtp-password
FINOPS_WEB_SMTP_USE_TLS=true
